HOST=0.0.0.0
PORT=8000

LIGHTS_MAP='{"ceiling_strip":"192.168.1.123"}'
GARAGE_OPENER_HOST=http://192.168.1.100
DEFAULT_DOOR_ALIASES='{"1":["north","left","1"],"2":["south","right","2"]}'

# comma-separated router prefixes (e.g. "lights,garage"); empty/unset => no auth
AUTH_REQUIRED=
# required when AUTH_REQUIRED is non-empty; clients send it via `X-API-Key` header
AUTH_API_KEY=